{
  "name": "trawl",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "dev:obsidian-plugin": "turbo dev --filter=obsidian-plugin",
    "build": "turbo build",
    "build:obsidian-plugin": "turbo build --filter=obsidian-plugin",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:api": "turbo test --filter=api"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
