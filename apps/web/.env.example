# Internal Trawl API URL for server-side calls from the web container.
# When web and api run in the same docker-compose project, use the service name.
TRAWL_API_URL=http://api:3100

# Public or tailnet URL for links rendered into the browser.
# Example: https://trawl-api.your-tailnet.ts.net or http://your-server:3100
TRAWL_PUBLIC_API_URL=http://localhost:3100

# API key for the web app's server-side requests.
# Must match one accepted token from API_KEY or API_KEYS in apps/api/.env.
TRAWL_API_KEY=change-me
