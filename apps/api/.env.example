# Server port
PORT=3100

# Accepted Bearer token for authenticated API clients.
# Generate a strong value with: openssl rand -hex 32
API_KEY=replace-with-a-random-secret

# Optional additional accepted Bearer tokens for client-specific credentials or rotation.
# Comma-separate multiple values.
# API_KEYS=obsidian-token,automation-token

# SQLite database path (relative to apps/api)
DB_PATH=./data/trawl.db

# Ollama URL (use host.docker.internal from Docker)
OLLAMA_URL=http://host.docker.internal:11434

# LLM models
SUMMARY_MODEL=qwen3:8b
EMBEDDING_MODEL=nomic-embed-text
TAGGING_MODEL=qwen3:8b

# Similarity threshold for graph edges
SIMILARITY_THRESHOLD=0.75
