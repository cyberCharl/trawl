# Server port. Defaults to 3000.
PORT=3100

# API key used for Authorization: Bearer <key> requests.
API_KEY=change-me

# SQLite database path. Defaults to ./data/trawl.db
DB_PATH=./data/trawl.db

# Local Ollama base URL for summarisation, tagging, and embeddings.
OLLAMA_URL=http://localhost:11434

# LLM used for 2-3 sentence summaries.
SUMMARY_MODEL=qwen3:8b

# Embedding model. Run `ollama pull nomic-embed-text` if it is not installed.
EMBEDDING_MODEL=nomic-embed-text

# LLM used for auto-tagging.
TAGGING_MODEL=qwen3:8b

# Similarity cutoff for semantic graph edges.
SIMILARITY_THRESHOLD=0.75
